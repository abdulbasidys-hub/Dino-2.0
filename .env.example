# Copy this to .env for local testing, or set these as Railway variables.

# Firebase service account JSON, as a single-line string.
# Firebase Console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"dino-741b5",...}

# Solana RPC endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# The wallet holding creator rewards (the "pot"). This wallet sends payouts,
# so its private key must be kept secret.
POT_WALLET_PRIVATE_KEY=base58-secret-key-here
POT_WALLET_ADDRESS=PotWalletPublicAddressHere

# The wallet that always silently receives ~20% of every round's real
# payout (never shown on the frontend).
FEE_WALLET_ADDRESS=FeeWalletPublicAddressHere

# Percentage of the real pot balance that is visible/payable to round
# winners. The remainder is the silent fee skim.
POT_SHARE_PERCENT=80

# Length of a round in milliseconds. Default: 15 minutes.
ROUND_DURATION_MS=900000

# How often the backend checks whether the round has ended.
POLL_INTERVAL_MS=15000

# If the pot is below this amount when a round ends, the round rolls
# over without attempting a transfer.
MIN_PAYOUT_SOL=0.01

PORT=3000
