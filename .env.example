# Copy this to .env for local testing, or set these as Railway variables.

# Firebase service account JSON, as a single-line string.
# Firebase Console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"dino-741b5",...}

# Solana RPC endpoint. The public default is rate-limited — for real
# traffic, use a free-tier key from Helius, QuickNode, or similar.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# The wallet holding creator rewards (the "pot"). This wallet sends payouts,
# so its private key must be kept secret.
POT_WALLET_PRIVATE_KEY=base58-secret-key-here
POT_WALLET_ADDRESS=PotWalletPublicAddressHere

# The TEAM wallet. Receives 20% of the pot's real balance EVERY round,
# unconditionally, before any winner payout is calculated.
FEE_WALLET_ADDRESS=FeeWalletPublicAddressHere

# Your token's mint/contract address. Used by claimFees.js to monitor
# accumulating creator rewards, AND by the holding-check (price lookup
# + balance check) that gates every round payout.
TOKEN_CA=YourTokenMintAddressHere

# ── Token-holding gate ──────────────────────────────────────────
# Minimum SOL-equivalent value of the token a wallet must CURRENTLY
# hold for its score to count toward any payout. Verified live via
# DexScreener price + an on-chain balance read, re-checked here right
# before paying anyone (the frontend check alone isn't trustworthy).
MIN_HOLDING_SOL=0.2

# ── Round payout amounts ────────────────────────────────────────
# Fixed SOL amounts paid to 1st/2nd/3rd place each round, when the
# pot's distributable 80% can afford the full set. If it can't, the
# backend falls back to splitting whatever's available as 50/30/20
# instead (same unfilled-rank-rolls-over rule either way).
FIXED_FIRST_SOL=1
FIXED_SECOND_SOL=0.5
FIXED_THIRD_SOL=0.3

# ── Hall of Fame / Winners Board ────────────────────────────────
# Flat reward for the single Winners Board payout each round, once
# unlocked, paid from whatever's left after the regular round payout.
WINNERS_BOARD_REWARD_SOL=0.5
# Number of all-time #1 round winners required before the Winners
# Board starts paying out (one inductee per round, by definition, so
# this is also the minimum number of rounds before it can unlock).
WINNERS_BOARD_UNLOCK_COUNT=5

# Length of a round in milliseconds. Default: 15 minutes.
ROUND_DURATION_MS=900000

# How often the backend checks whether the round has ended.
POLL_INTERVAL_MS=15000

# If the pot is below this amount when a round ends, the round rolls
# over without attempting any transfer at all (not even the team cut).
MIN_PAYOUT_SOL=0.01

PORT=3000
